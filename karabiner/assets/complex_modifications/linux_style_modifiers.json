{
  "title": "Linux-style Ctrl Behavior (Text + Clipboard)",
  "rules": [
    {
      "description": "Stop siren (pkill afplay)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "f",
            "modifiers": {
              "mandatory": [
                "option"
              ]
            }
          },
          "to": [
            {
              "shell_command": "pkill afplay"
            }
          ]
        }
      ]
    },
    {
      "description": "Globe key → Left Control",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "fn"
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ]
        }
      ]
    },
