#!/usr/bin/env zsh

# clear

# -------- Terminal --------
TERM_TEXT="$TERM"

# -------- Shell --------
SHELL_NAME=$(basename "$SHELL")
SHELL_VERSION="${ZSH_VERSION:-$BASH_VERSION}"
SHELL_TEXT="$SHELL_NAME $SHELL_VERSION"

# -------- Uptime (Linux + macOS compatible) --------
if uptime -p >/dev/null 2>&1; then
  # Linux (GNU coreutils)
  UPTIME_TEXT=$(uptime -p | sed 's/^up //')
else
  # macOS / BSD
  UPTIME_TEXT=$(uptime | sed 's/.*up \([^,]*\), .*/\1/')
fi

# -------- Username (zsh uppercase expansion works everywhere zsh exists) --------
USER_UPPER="${(U)USER}"

# -------- figlet check --------
if command -v figlet >/dev/null 2>&1; then
  LEFT=$(figlet "$USER_UPPER")
else
  LEFT="$USER_UPPER"
fi

# -------- Output --------
paste <(echo "$LEFT") <(
  print -P "%F{green}%B Terminal:%f%b $TERM_TEXT\n\n%F{green}%B Uptime:%f%b $UPTIME_TEXT\n\n%F{green}%B Shell:%f%b $SHELL_TEXT\n"
)
